[Unit]
Description=Ollama embedding server (loopback-only)
After=network-online.target
Wants=network-online.target

[Service]
Type=exec
ExecStart=/usr/local/bin/ollama serve
# Bind loopback only — Ollama's installer default is 0.0.0.0:11434, which
# would expose embeddings to the public internet on a fresh box. We rely on
# this being unreachable from outside the VPS.
Environment="OLLAMA_HOST=127.0.0.1:11434"
User=ollama
Group=ollama
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
