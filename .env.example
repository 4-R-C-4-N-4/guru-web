# .env.local (development) — copy to .env.local and fill in values.
#
# Production: these vars live in /etc/guru-web.env (mode 0600, root:root),
# loaded by deploy/guru-web.service via EnvironmentFile=. Never commit
# production secrets to the repo.

# Postgres
DATABASE_URL=postgresql://guru:password@localhost:5432/guru

# OpenRouter (chat completions)
OPENROUTER_API_KEY=

# Ollama (query embeddings — nomic-embed-text:v1.5).
# Prod always points at localhost (Ollama runs as a systemd unit on the same
# VPS, bound to 127.0.0.1:11434). Dev defaults to localhost too; override only
# if pointing at a remote Ollama for testing.
# OLLAMA_URL=http://localhost:11434

# Sent as HTTP-Referer to OpenRouter (see src/lib/model.ts).
# In prod set to https://<your-domain>; defaults to http://localhost:3000.
# NEXT_PUBLIC_APP_URL=

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=price_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
